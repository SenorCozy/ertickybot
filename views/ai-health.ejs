<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>AI Health Logs</title>
    <link rel="stylesheet" href="/ai-health.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  </head>

  <body>
    <div class="container">
      <h1>🧠 Full AI Health Overview</h1>
      <p style="text-align: center">
        Welcome, <strong><%= user.username %></strong>
      </p>

      <!-- 🔢 Summary Info -->
      <div class="summary-box">
        <div><strong>Total Logs:</strong> <%= logs.length %></div>
        <div id="last-entry" data-ts="<%= logs[0] ? logs[0].timestamp : '' %>">
          <strong>Last Entry:</strong>
          <span class="timestamp-text"><%= logs[0] ? 'Loading…' : 'N/A' %></span>
          <span class="timestamp-relative"></span>
        </div>
      </div>

      <!-- 📈 Chart Placeholders -->
      <div class="charts">
        <canvas id="successRateChart"></canvas>
        <canvas id="fallbackRateChart"></canvas>
      </div>

      <!-- 📝 Log Table -->
      <h2>Recent AI Logs</h2>
      <div class="table-container">
        <table>
          <thead>
            <tr>
              <th>Timestamp</th>
              <th>User ID</th>
              <th>Context</th>
              <th>Model</th>
              <th>Prompt Length</th>
              <th>Time (ms)</th>
              <th>Success</th>
              <th>Fallback</th>
              <th>Error</th>
            </tr>
          </thead>
          <tbody>
            <% logs.forEach(log => { %>
              <tr>
                <td class="local-timestamp" data-ts="<%= log.timestamp %>"></td>
                <td><%= log.user_id %></td>
                <td><%= String(log.ticket_id).startsWith("ai_channel") ? "AI Chat" : "Ticket" %></td>
                <td><%= log.model_used %></td>
                <td><%= log.prompt_length %></td>
                <td><%= log.response_time_ms %></td>
                <td><%= log.success ? "✅" : "❌" %></td>
                <td><%= log.fallback_used ? "🔁" : "—" %></td>
                <td><%= log.error_message || "—" %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <p style="text-align: center; margin-top: 20px;">
        <a href="/dashboard" class="transcript-view">⬅️ Back to Dashboard</a>
      </p>
    </div>

    <!-- 📊 Charts + Timestamp Localization -->
    <script>
      const successCount = <%= successCount %>;
      const failCount = <%= failCount %>;
      const fallbackCount = <%= fallbackCount %>;
      const directSuccessCount = <%= directSuccessCount %>;

      const ctx1 = document.getElementById('successRateChart').getContext('2d');
      const ctx2 = document.getElementById('fallbackRateChart').getContext('2d');

      new Chart(ctx1, {
        type: 'doughnut',
        data: {
          labels: ['Success', 'Failure'],
          datasets: [{
            label: 'Success Rate',
            data: [successCount, failCount],
            backgroundColor: ['#22c55e', '#ef4444'],
          }]
        }
      });

      new Chart(ctx2, {
        type: 'doughnut',
        data: {
          labels: ['Fallback Used', 'Direct Success'],
          datasets: [{
            label: 'Fallback Rate',
            data: [fallbackCount, directSuccessCount],
            backgroundColor: ['#facc15', '#60a5fa'],
          }]
        }
      });

      const opts = { 
  timeZone: Intl.DateTimeFormat().resolvedOptions().timeZone, 
  year: "numeric", month: "numeric", day: "numeric",
  hour: "numeric", minute: "numeric", second: "numeric",
  hour12: true
};

document.querySelectorAll(".local-timestamp").forEach(td => {
  const ts = td.getAttribute("data-ts");
  const date = new Date(ts); // ✅ parse string timestamp
  td.textContent = `${date.toLocaleString(undefined, opts)} (${timeAgo(date)})`;
});

const lastEntryContainer = document.getElementById("last-entry");
if (lastEntryContainer) {
  const ts = lastEntryContainer.getAttribute("data-ts");
  if (ts) {
    const date = new Date(ts); // ✅ parse string timestamp
    lastEntryContainer.querySelector(".timestamp-text").textContent = date.toLocaleString(undefined, opts);
  }
}

function timeAgo(date) {
  const seconds = Math.floor((new Date() - date) / 1000);
  if (seconds < 60) return 'just now';
  const minutes = Math.floor(seconds / 60);
  if (minutes < 60) return `${minutes} minute${minutes === 1 ? '' : 's'} ago`;
  const hours = Math.floor(minutes / 60);
  if (hours < 24) return `${hours} hour${hours === 1 ? '' : 's'} ago`;
  const days = Math.floor(hours / 24);
  return `${days} day${days === 1 ? '' : 's'} ago`;
}

    </script>
  </body>
</html>
